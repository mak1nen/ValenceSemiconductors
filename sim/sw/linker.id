OUTPUT_ARCH(riscv)
ENTRY(_start)

MEMORY {
  SRAM (rwx) : ORIGIN = 0x20000000, LENGTH = 64K
  /* DRAM (rwx) : ORIGIN = 0x80000000, LENGTH = 256M */
  /* Uncomment when DRAM controller is added to SoC */
}

SECTIONS {
  .text : {
    *(.text.start)
    *(.text*)
  } > SRAM

  .rodata : {
    *(.rodata*)
  } > SRAM

  .data : {
    *(.data*)
  } > SRAM

  .bss : {
    _bss_start = .;
    *(.bss*)
    *(COMMON)
    _bss_end = .;
  } > SRAM

  _stack_top = ORIGIN(SRAM) + LENGTH(SRAM);
}